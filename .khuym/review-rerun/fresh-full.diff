+        </div>
+        <div>
+          <dt>S? c?nh báo</dt>
+          <dd>{{ health.alert_count }}</dd>
+        </div>
+        <div>
+          <dt>S? b?t thu?ng</dt>
+          <dd>{{ health.anomaly_count }}</dd>
+        </div>
+        <div>
+          <dt>C?a s? (giây)</dt>
