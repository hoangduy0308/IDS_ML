# Same-host IDS operator console environment template.
# Copy to /etc/ids-operator-console/ids-operator-console.env and adjust for the target host.
#
# These values are the sole configuration source for the systemd services.
# The EnvironmentFile= directive in the service units loads this file.

IDS_OPERATOR_CONSOLE_ENVIRONMENT=production
IDS_OPERATOR_CONSOLE_HOST=127.0.0.1
IDS_OPERATOR_CONSOLE_PORT=8765
IDS_OPERATOR_CONSOLE_LOG_LEVEL=info
IDS_OPERATOR_CONSOLE_FORWARDED_ALLOW_IPS=127.0.0.1
IDS_OPERATOR_CONSOLE_ROOT_PATH=
IDS_OPERATOR_CONSOLE_PUBLIC_BASE_URL=https://console.example
IDS_OPERATOR_CONSOLE_SESSION_COOKIE_NAME=ids_operator_session

IDS_OPERATOR_CONSOLE_DATABASE_PATH=/var/lib/ids-operator-console/operator_console.db
IDS_OPERATOR_CONSOLE_ALERTS_INPUT_PATH=/var/log/ids-live-sensor/ids_live_alerts.jsonl
IDS_OPERATOR_CONSOLE_QUARANTINE_INPUT_PATH=/var/log/ids-live-sensor/ids_live_quarantine.jsonl
IDS_OPERATOR_CONSOLE_SUMMARY_INPUT_PATH=/var/log/ids-live-sensor/ids_live_sensor_summary.jsonl

IDS_OPERATOR_CONSOLE_TEMPLATES_DIR=/opt/ids_ml_new/ids/console/templates
IDS_OPERATOR_CONSOLE_STATIC_DIR=/opt/ids_ml_new/ids/console/static

IDS_OPERATOR_CONSOLE_SECRET_KEY_FILE=/etc/ids-operator-console/console.secret

# --- Telegram Notifications ---
# Two configuration approaches:
#   1. Env file (below): Set these for initial/headless bootstrap.
#   2. Settings UI: After bootstrap, configure Telegram at /settings in the dashboard.
#
# DB settings (configured via Settings UI) take precedence over these env values.
# The notification worker checks the database every 30 seconds for updates.
#
# To use env-file approach: set both BOT_TOKEN (or _FILE) and CHAT_ID.
# To use Settings UI approach: leave these blank and configure via /settings after login.
IDS_OPERATOR_CONSOLE_TELEGRAM_BOT_TOKEN=
IDS_OPERATOR_CONSOLE_TELEGRAM_BOT_TOKEN_FILE=/etc/ids-operator-console/telegram-bot-token.secret
IDS_OPERATOR_CONSOLE_TELEGRAM_CHAT_ID=
