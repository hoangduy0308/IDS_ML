+        </div>
+        <div>
+          <dt>Đích rollback</dt>
+          <dd>{{ health.active_bundle.previous_bundle_name if health.active_bundle and health.active_bundle.previous_bundle_name else "Không có" }}</dd>
+        </div>
+      </dl>
+    </article>
+
+    <article class="panel">
+      <div class="section-heading">
+        <div>
+          <span class="eyebrow">Readyz</span>
+          <h3>Đ? s?n sŕng thŕnh ph?n</h3>
+        </div>
+      </div>
+      <div class="readiness-stack">
+        <div class="readiness-item">
+          <span>Schema</span>
+          <strong>{{ state_labels.get(readiness.components.schema.state, readiness.components.schema.state) }}</strong>
+        </div>
+        <div class="readiness-item">
+          <span>Bootstrap qu?n tr?</span>
+          <strong>{{ readiness.components.admin_bootstrap.admin_count }}</strong>
+        </div>
+        <div class="readiness-item">
+          <span>Đu?ng d?n d? li?u</span>
+          <strong>{{ "?n d?nh" if readiness.components.data_paths.ok else "Suy gi?m" }}</strong>
+        </div>
+        <div class="readiness-item">
+          <span>Thông báo</span>
+          <strong>{{ state_labels.get(readiness.components.notification.state, readiness.components.notification.state) }}</strong>
+        </div>
+      </div>
+    </article>
+  </aside>
+</section>
+
+<section class="panel">
+  <div class="section-heading">
+    <div>
+      <span class="eyebrow">Lane v?n hŕnh</span>
+      <h3>Xem nhanh b?t thu?ng</h3>
+    </div>
+    <a href="/operations" class="button button-secondary">M? v?n hŕnh</a>
+  </div>
+  {% if anomalies %}
+  <table class="data-table">
+    <thead>
+      <tr>
+        <th>ID</th>
+        <th>Lo?i</th>
+        <th>Lý do</th>
+        <th>Th?i di?m</th>
+      </tr>
+    </thead>
+    <tbody>
+      {% for anomaly in anomalies[:6] %}
+      <tr>
+        <td>{{ anomaly.id }}</td>
+        <td>{{ anomaly.anomaly_type }}</td>
+        <td>{{ anomaly.reason or anomaly.redacted_summary or "-" }}</td>
