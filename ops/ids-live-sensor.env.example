# Same-host IDS live-sensor environment template.
# Copy to /etc/ids-live-sensor/ids-live-sensor.env and adjust for the target host.
#
# These values are the sole configuration source for the live-sensor service.
# The EnvironmentFile= directive in the service unit loads this file.
# IDS_LIVE_SENSOR_EXTRACTOR_COMMAND_PREFIX must remain one executable path so
# install-time bootstrap and steady-state service restarts use the same argv.

IDS_LIVE_SENSOR_INTERFACE=eth0
IDS_LIVE_SENSOR_SPOOL_DIR=/var/lib/ids-live-sensor
IDS_LIVE_SENSOR_ALERTS_OUTPUT=/var/log/ids-live-sensor/ids_live_alerts.jsonl
IDS_LIVE_SENSOR_QUARANTINE_OUTPUT=/var/log/ids-live-sensor/ids_live_quarantine.jsonl
IDS_LIVE_SENSOR_SUMMARY_OUTPUT=/var/log/ids-live-sensor/ids_live_sensor_summary.jsonl
IDS_LIVE_SENSOR_DUMPCAP_BINARY=/usr/bin/dumpcap
IDS_LIVE_SENSOR_EXTRACTOR_COMMAND_PREFIX=/opt/ids_ml_new/.venv/bin/ids-offline-window-extractor
IDS_LIVE_SENSOR_ACTIVE_BUNDLE_PATH=/var/lib/ids-live-sensor/active_bundle.json
