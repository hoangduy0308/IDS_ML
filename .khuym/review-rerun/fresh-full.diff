-    for field in ("active_bundle_root", "previous_bundle_root"):
-        raw_root = payload.get(field)
-        if raw_root in (None, ""):
-            continue
-        resolved_root = Path(str(raw_root)).resolve()
-        referenced_bundle_roots.append(
-            {
-                "field": field,
-                "path": str(resolved_root),
-                "exists": resolved_root.is_dir(),
