+    ]
+    version_lines = [
+        f'kaggle datasets version -p "{dataset_bundle_dir}" -m "Refresh frozen binary IDS split" -q',
+        "",
+    ]
+    push_lines = [f'kaggle kernels push -p "{kernel_dir}"' for kernel_dir in kernel_dirs]
+    status_lines = [
